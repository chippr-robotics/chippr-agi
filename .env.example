# Model provider: 'claude' or 'local'
CHIPPR_MODEL_PROVIDER=claude

# Claude provider settings
CHIPPR_CLAUDE_MODEL=sonnet
ANTHROPIC_API_KEY=

# Local model settings (Ollama, llama.cpp, BitNet)
CHIPPR_LOCAL_URL=http://localhost:11434/v1
CHIPPR_LOCAL_MODEL=bitnet-b1.58

# Storage
CHIPPR_DB_PATH=./chippr.db

# Container isolation
CHIPPR_CONTAINER_RUNTIME=docker
CHIPPR_CONTAINER_IMAGE=chippr-agent:latest

# Logging
CHIPPR_LOG_LEVEL=info
